{
  "name": "@prodbysolivan/journal",
  "description": "A lightweight journaling system designed for modularity and seamless message observability.",
  "version": "1.0.3",
  "exports": "./source/index.ts",
  "publish": {
    "include": ["source/**/*.ts", "deno.json", "README.md", "LICENSE"]
  },
  "lint": {
    "rules": {
      "exclude": ["adjacent-overload-signatures"]
    }
  },
  "tasks": {
    "format": "deno fmt",
    "lint": "deno lint",
    "clean": "rm -rf build"
  },
  "imports": {
    "@prodbysolivan/history": "jsr:@prodbysolivan/history@^1.0.1",
    "@prodbysolivan/signal": "jsr:@prodbysolivan/signal@^1.2.0",
    "@prodbysolivan/types": "jsr:@prodbysolivan/types@^1.0.2",
    "@std/assert": "jsr:@std/assert@^1.0.19"
  }
}
